# =====================================================================
#  Konfigurasi Apache (lokal/XAMPP, atau jika kelak pindah ke hosting Apache).
#
#  PENTING: hosting produksi saat ini memakai **nginx**, yang TIDAK PERNAH
#  membaca .htaccess. Karena itu aplikasi sengaja dirancang agar berjalan
#  TANPA bergantung pada berkas ini:
#
#    - Tidak ada mod_rewrite / funnel. Struktur folder = struktur URL.
#    - Clean-URL (mis. /laporan/bulan) memakai folder berisi index.php,
#      yang dilayani baik oleh Apache (DirectoryIndex) maupun nginx (index).
#
#  Jadi berkas ini murni penyempurna di Apache — bukan syarat agar app jalan.
# =====================================================================

Options +FollowSymLinks -MultiViews
DirectoryIndex index.php index.html

# Jangan tampilkan daftar isi folder.
Options -Indexes

# Jangan layani berkas konfigurasi PHP per-direktori lewat HTTP.
<FilesMatch "^\.user\.ini$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
